@model TaskTracker.Models.AppUser
@{
    ViewData["Title"] = "My Profile";
    var imgPath = Model.ProfileImagePath;
    var initials = string.Concat(Model.DisplayName.Split(' ').Select(w => w.Length > 0 ? w[0].ToString() : "")).ToUpper();
    if (initials.Length > 2) initials = initials[..2];
}

<div class="max-w-2xl mx-auto space-y-6">

    <div class="page-hd">
        <div class="page-hd-left">
            <h1>My Profile</h1>
            <p>Manage your account settings</p>
        </div>
    </div>

    @* ── Profile info ── *@
    <div class="bg-white border border-gray-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-gray-700 mb-5">Profile Photo &amp; Info</h2>
        <form method="post" action="/Profile/UpdateProfile" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="flex items-start gap-6 mb-5">
                <!-- Avatar -->
                <div class="flex-shrink-0">
                    @if (!string.IsNullOrEmpty(imgPath))
                    {
                        <img src="@imgPath" alt="avatar"
                             class="w-20 h-20 rounded-full object-cover border-2 border-gray-200" />
                    }
                    else
                    {
                        <div class="w-20 h-20 rounded-full flex items-center justify-center text-white text-2xl font-bold" style="background:var(--brand)">
                            @initials
                        </div>
                    }
                </div>
                <div class="flex-1">
                    <label class="block text-xs font-medium text-gray-500 mb-1">Upload photo</label>
                    <input type="file" name="avatar" accept="image/*"
                           class="block w-full text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                    <p class="text-xs text-gray-400 mt-1">JPG, PNG, GIF or WebP · max 3 MB</p>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4 mb-5">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">Username</label>
                    <input type="text" value="@Model.Username" disabled
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">Role</label>
                    <input type="text" value="@Model.Role" disabled
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-medium text-gray-500 mb-1">Display Name <span class="text-gray-400">(shown in task owner field)</span></label>
                    <input type="text" name="displayName" value="@Model.DisplayName" required
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>
            </div>
            <button type="submit" class="btn-primary text-sm px-5 py-2 rounded-lg">Save Changes</button>
        </form>
    </div>

    @* ── Change password ── *@
    <div class="bg-white border border-gray-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-gray-700 mb-5">Change Password</h2>
        <form method="post" action="/Profile/ChangePassword">
            @Html.AntiForgeryToken()
            <div class="space-y-4 mb-5">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">Current Password</label>
                    <input type="password" name="currentPassword" required autocomplete="current-password"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">New Password</label>
                    <input type="password" name="newPassword" required autocomplete="new-password"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">Confirm New Password</label>
                    <input type="password" name="confirmPassword" required autocomplete="new-password"
                           class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>
            </div>
            <button type="submit" class="btn-primary text-sm px-5 py-2 rounded-lg">Change Password</button>
        </form>
    </div>

    @* ── Notification preferences ── *@
    <div class="bg-white border border-gray-200 rounded-xl p-6">
        <h2 class="text-sm font-semibold text-gray-700 mb-5">Notification Preferences</h2>
        <form method="post" action="/Profile/UpdateNotifications">
            @Html.AntiForgeryToken()
            <div class="space-y-3 mb-5">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="notifyOnAssigned" value="true"
                           @(Model.NotifyOnAssigned ? "checked" : "")
                           class="w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" />
                    <div>
                        <p class="text-sm font-medium text-gray-800">Notify when assigned to a task</p>
                        <p class="text-xs text-gray-500">Receive a bell notification when someone assigns you to a task</p>
                    </div>
                </label>
            </div>
            <button type="submit" class="btn-primary text-sm px-5 py-2 rounded-lg">Save Preferences</button>
        </form>
    </div>

</div>

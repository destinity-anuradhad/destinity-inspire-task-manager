<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Team Destinity Inspire</title>
    <link rel="icon" type="image/x-icon" href="/assets/img/destinity-inspire.ico" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/brand.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <style>
        /* SweetAlert2 brand overrides */
        .swal2-popup { font-family: 'Inter', sans-serif !important; border-radius: 1rem !important; }
        .swal2-title  { font-size: 1.05rem !important; font-weight: 700 !important; color: #0f172a !important; }
        .swal2-html-container { font-size: .875rem !important; color: #475569 !important; }
        .swal2-toast  { border-radius: .875rem !important; font-family: 'Inter', sans-serif !important; }
        .swal2-toast .swal2-title { font-size: .875rem !important; font-weight: 500 !important; color: #0f172a !important; }
        .swal2-toast.swal2-popup { padding: .6rem 1rem !important; }
        .swal2-confirm { font-family: 'Inter', sans-serif !important; font-weight: 600 !important; border-radius: .5rem !important; }
        .swal2-cancel  { font-family: 'Inter', sans-serif !important; font-weight: 500 !important; border-radius: .5rem !important; }
    </style>
    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- ── Top Navigation ─────────────────────────────────────────── -->
    <nav class="nav-brand shadow-md sticky top-0 z-40">
        <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">

                <!-- Brand -->
                <a href="/Dashboard" class="flex items-center gap-3 flex-shrink-0">
                    <img src="/assets/img/destinity-inspire.svg" alt="Destinity Inspire"
                         class="h-9 w-auto" onerror="this.style.display='none'" />
                    <div class="hidden sm:block">
                        <span class="font-bold text-white text-sm leading-none tracking-tight">Team Destinity Inspire</span>
                        <span class="text-white/45 text-[10px] block leading-none mt-0.5 font-medium tracking-wide uppercase">Task Tracker</span>
                    </div>
                </a>

                <!-- Nav Links -->
                @{
                    var activeNav   = ViewData["ActiveNav"] as string ?? "";
                    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "";
                    var imgPath     = User.FindFirst("ProfileImagePath")?.Value ?? "";
                    var navInitials = displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "?";
                }
                <div class="flex items-center gap-0.5">
                    <a href="/Dashboard"
                       class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-all @(activeNav == "Dashboard" ? "nav-link-active" : "nav-link-idle")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Dashboard
                    </a>
                    <a href="/Tasks"
                       class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-all @(activeNav == "Tasks" ? "nav-link-active" : "nav-link-idle")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        Tasks
                    </a>
                    <a href="/Dashboard/Team"
                       class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-all @(activeNav == "Team" ? "nav-link-active" : "nav-link-idle")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        Team
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                    <a href="/Master"
                       class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-all @(activeNav == "Master" ? "nav-link-active" : "nav-link-idle")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Master Files
                    </a>
                    }
                    <a href="/Activity"
                       class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-all @(activeNav == "Activity" ? "nav-link-active" : "nav-link-idle")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Activity
                    </a>
                </div>

                <!-- Right: bell + user menu -->
                <div class="flex items-center gap-1">

                    @* ── Notification Bell ── *@
                    <div class="relative" id="notifWrap">
                        <button id="notifBtn" onclick="toggleNotif()"
                                class="relative p-2 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                            </svg>
                            <span id="notifBadge"
                                  class="hidden absolute top-1 right-1 w-4 h-4 bg-[#f47920] text-white text-[9px] font-bold rounded-full flex items-center justify-center leading-none">
                            </span>
                        </button>
                        <div id="notifDropdown"
                             class="hidden absolute right-0 top-full mt-2 w-80 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 overflow-hidden">
                            <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 bg-gray-50">
                                <span class="text-sm font-semibold text-gray-800">Notifications</span>
                                <button onclick="markAllRead()" class="text-xs text-[#094f70] hover:underline font-medium">Mark all read</button>
                            </div>
                            <div id="notifList" class="max-h-72 overflow-y-auto p-2">
                                <div class="py-8 flex flex-col items-center gap-2 text-gray-400">
                                    <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                                    </svg>
                                    <span class="text-xs">Loading…</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ── User Menu ── *@
                    <div class="relative" id="userMenuWrap">
                        <button onclick="toggleUserMenu()"
                                class="flex items-center gap-2 pl-1 pr-2.5 py-1.5 rounded-lg hover:bg-white/10 transition-colors">
                            @if (!string.IsNullOrEmpty(imgPath))
                            {
                                <img src="@imgPath" alt="avatar" class="w-7 h-7 rounded-full object-cover ring-2 ring-white/30" />
                            }
                            else
                            {
                                <div class="w-7 h-7 rounded-full bg-[#f47920] flex items-center justify-center text-white text-xs font-bold ring-2 ring-white/20">@navInitials</div>
                            }
                            <span class="text-sm font-medium text-white/90 hidden sm:block">@displayName</span>
                            <svg class="w-3.5 h-3.5 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div id="userMenuDropdown"
                             class="hidden absolute right-0 top-full mt-2 w-48 bg-white rounded-xl shadow-2xl border border-gray-100 z-50 py-1 overflow-hidden">
                            <div class="px-4 py-3 border-b border-gray-100">
                                <p class="text-xs font-semibold text-gray-900 truncate">@displayName</p>
                                <p class="text-[11px] text-gray-400 mt-0.5">@(User.IsInRole("Admin") ? "Administrator" : "Member")</p>
                            </div>
                            <a href="/Profile"
                               class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                My Profile
                            </a>
                            <div class="border-t border-gray-100 my-1"></div>
                            <form method="post" action="/Account/Logout">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                    </svg>
                                    Sign Out
                                </button>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <!-- ── Main Content ──────────────────────────────────────────── -->
    <main class="flex-1 max-w-screen-2xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">
        @RenderBody()
    </main>

    <!-- ── Footer ────────────────────────────────────────────────── -->
    <footer class="mt-auto border-t border-white/60" style="background:rgba(255,255,255,0.7);backdrop-filter:blur(8px)">
        <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <img src="/assets/img/destinity-inspire.svg" alt="" class="h-4 w-auto opacity-40"
                     onerror="this.style.display='none'" />
                <p class="text-[11px] text-gray-400 font-medium">Team Destinity Inspire &copy; 2026</p>
            </div>
            <p class="text-[10px] text-gray-300 font-medium tracking-wide uppercase">Scienter PMS</p>
        </div>
    </footer>

    @{
        var _tMsgs = new System.Collections.Generic.List<(string Msg, string Type)>();
        string? _tv;
        _tv = TempData["ProfileSuccess"]  as string; if (!string.IsNullOrEmpty(_tv)) _tMsgs.Add((_tv,"success"));
        _tv = TempData["PasswordSuccess"] as string; if (!string.IsNullOrEmpty(_tv)) _tMsgs.Add((_tv,"success"));
        _tv = TempData["NotifSuccess"]    as string; if (!string.IsNullOrEmpty(_tv)) _tMsgs.Add((_tv,"success"));
        _tv = TempData["ProfileError"]    as string; if (!string.IsNullOrEmpty(_tv)) _tMsgs.Add((_tv,"error"));
        _tv = TempData["PasswordError"]   as string; if (!string.IsNullOrEmpty(_tv)) _tMsgs.Add((_tv,"error"));
        _tv = TempData["Error"]           as string; if (!string.IsNullOrEmpty(_tv)) _tMsgs.Add((_tv,"error"));
        var _tdJs = new System.Text.StringBuilder();
        foreach (var _tm in _tMsgs)
            _tdJs.Append($"showToast({System.Text.Json.JsonSerializer.Serialize(_tm.Msg)},'{_tm.Type}');");
    }

    @* ── SweetAlert2 Toast + Confirm helpers (defined BEFORE @RenderSectionAsync) ── *@
    <script>
    // ── showToast — wraps Swal toast ──────────────────────────────────────────
    function showToast(msg, type, dur) {
        if (!msg) return;
        type = type || 'info';
        dur  = dur  || 4000;
        Swal.fire({
            toast: true,
            position: 'top-end',
            icon: type,
            title: msg,
            showConfirmButton: false,
            timer: dur,
            timerProgressBar: true,
            showCloseButton: true,
            customClass: { popup: 'swal2-toast' },
        });
    }

    // ── swalDelete — confirm before a form-POST delete ────────────────────────
    function swalDelete(form, name) {
        Swal.fire({
            title: 'Delete ' + (name ? '“' + name + '”' : 'this item') + '?',
            text: 'This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Yes, delete',
            cancelButtonText: 'Cancel',
            reverseButtons: true,
            focusCancel: true,
        }).then(function(r) { if (r.isConfirmed) form.submit(); });
    }

    // ── TempData server-side toasts ───────────────────────────────────────────
    @Html.Raw(_tdJs.ToString())

    // ── sessionStorage pending toast (after page reload e.g. task save) ──────
    (function(){
        try {
            var pt = sessionStorage.getItem('__toast');
            if (pt) {
                sessionStorage.removeItem('__toast');
                var d = JSON.parse(pt);
                showToast(d.msg, d.type || 'info', d.dur || 4000);
            }
        } catch(e) {}
    })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    // ── Notification bell ──────────────────────────────────
    let notifOpen = false;
    async function toggleNotif() {
        notifOpen = !notifOpen;
        document.getElementById('notifDropdown').classList.toggle('hidden', !notifOpen);
        if (notifOpen) {
            const r = await fetch('/Account/NotificationList');
            document.getElementById('notifList').innerHTML = await r.text();
        }
    }
    async function markAllRead() {
        const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
        await fetch('/Account/MarkAllRead', { method: 'POST', headers: { 'RequestVerificationToken': token } });
        document.getElementById('notifBadge').classList.add('hidden');
        const r = await fetch('/Account/NotificationList');
        document.getElementById('notifList').innerHTML = await r.text();
    }
    async function loadNotifCount() {
        try {
            const r = await fetch('/Account/NotificationCount');
            const j = await r.json();
            const b = document.getElementById('notifBadge');
            if (j.count > 0) {
                b.textContent = j.count > 99 ? '99+' : j.count;
                b.classList.remove('hidden');
            }
        } catch {}
    }
    loadNotifCount();

    // ── User menu ──────────────────────────────────────────
    function toggleUserMenu() {
        document.getElementById('userMenuDropdown').classList.toggle('hidden');
    }
    document.addEventListener('click', e => {
        if (!e.target.closest('#notifWrap')) {
            document.getElementById('notifDropdown').classList.add('hidden');
            notifOpen = false;
        }
        if (!e.target.closest('#userMenuWrap')) {
            document.getElementById('userMenuDropdown').classList.add('hidden');
        }
    });
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            document.getElementById('notifDropdown').classList.add('hidden');
            document.getElementById('userMenuDropdown').classList.add('hidden');
            notifOpen = false;
        }
    });
    </script>
</body>
</html>

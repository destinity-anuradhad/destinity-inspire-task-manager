@model TaskTracker.Models.ViewModels.TaskListViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Tasks";
    var jsonOpts     = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var today        = DateTime.Today;
    var ownerColorMap = Model.Owners.ToDictionary(
        o => o.Name, o => o.Color ?? "#094f70", StringComparer.OrdinalIgnoreCase);
    var myDisplayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "";
}

@functions {
    static string PriorityBadge(string? p) => p switch
    {
        "P0" => "bg-red-100 text-red-700 border border-red-200",
        "P1" => "bg-orange-100 text-orange-700 border border-orange-200",
        "P2" => "bg-yellow-100 text-yellow-700 border border-yellow-200",
        "P3" => "bg-gray-100 text-gray-600 border border-gray-200",
        _    => "bg-gray-100 text-gray-500 border border-gray-200"
    };

    static string StatusBadge(string? s) => s switch
    {
        "Done"        => "bg-green-100 text-green-700 border border-green-200",
        "On track"    => "bg-blue-100 text-blue-700 border border-blue-200",
        "Delayed"     => "bg-red-100 text-red-700 border border-red-200",
        "On hold"     => "bg-gray-100 text-gray-600 border border-gray-200",
        "Testing"     => "bg-amber-100 text-amber-700 border border-amber-200",
        "Not Started" => "bg-purple-100 text-purple-700 border border-purple-200",
        _             => "bg-gray-100 text-gray-500 border border-gray-200"
    };

    static bool IsOverdue(string? expectedEnd, string? status)
    {
        if (status is "Done" or "On hold") return false;
        if (string.IsNullOrEmpty(expectedEnd)) return false;
        return DateTime.TryParse(expectedEnd, out var d) && d.Date < DateTime.Today;
    }

    static IEnumerable<string> SplitOwners(string? owner) =>
        (owner ?? "").Split(',').Select(o => o.Trim()).Where(o => o.Length > 0);

    static string WeightLabel(decimal? w) => w switch {
        null or 0 => "",
        0.5m      => "30 min",
        1m        => "1 h",
        2m        => "2 h",
        3m        => "3 h",
        4m        => "4 h",
        8m        => "1 day",
        16m       => "2 days",
        24m       => "3 days",
        40m       => "1 week",
        _         => $"{w} h"
    };
}

@{
    var workStatesJson = JsonSerializer.Serialize(
        Model.WorkStates.Select(ws => new { name = ws.Name, color = ws.Color }),
        jsonOpts);
}

@{
    string SortUrl(string col)
    {
        var dir = Model.Sort == col && Model.SortDir == "asc" ? "desc" : "asc";
        return Url.Action("Index", new {
            search=Model.Search, project=Model.Project, property=Model.Property,
            owner=Model.Owner, status=Model.Status, priority=Model.Priority,
            dateFrom=Model.DateFrom, dateTo=Model.DateTo,
            page=1, pageSize=Model.PageSize, sort=col, sortDir=dir,
            view=Model.ViewMode, calYear=Model.CalYear, calMonth=Model.CalMonth
        }) ?? "#";
    }
    string SortIcon(string col)  => Model.Sort != col ? "⇅" : Model.SortDir == "asc" ? "↑" : "↓";
    string SortClass(string col) => Model.Sort == col ? "text-blue-600" : "text-gray-300 group-hover:text-blue-400";

    string ViewUrl(string v) => Url.Action("Index", new {
        search=Model.Search, project=Model.Project, property=Model.Property,
        owner=Model.Owner, status=Model.Status, priority=Model.Priority,
        dateFrom=Model.DateFrom, dateTo=Model.DateTo,
        pageSize=Model.PageSize, view=v, calYear=Model.CalYear, calMonth=Model.CalMonth
    }) ?? "#";

    string exportUrl = Url.Action("Export", new {
        search=Model.Search, project=Model.Project, property=Model.Property,
        owner=Model.Owner, status=Model.Status, priority=Model.Priority,
        dateFrom=Model.DateFrom, dateTo=Model.DateTo
    }) ?? "#";
}

<div class="space-y-4">

    <!-- ── Header ── -->
    <div class="page-hd">
        <div class="page-hd-left">
            <h1>Tasks</h1>
            <p>@Model.TotalCount task@(Model.TotalCount != 1 ? "s" : "") total</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            <div class="flex rounded-lg border border-gray-200 bg-white overflow-hidden text-sm">
                <a href="@ViewUrl("table")"
                   class="flex items-center gap-1.5 px-3 py-1.5 transition-colors @(Model.ViewMode=="table"?"bg-blue-600 text-white":"text-gray-600 hover:bg-gray-50")">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 6h18M3 14h18M3 18h18"/></svg>
                    Table
                </a>
                <a href="@ViewUrl("kanban")"
                   class="flex items-center gap-1.5 px-3 py-1.5 border-x border-gray-200 transition-colors @(Model.ViewMode=="kanban"?"bg-blue-600 text-white":"text-gray-600 hover:bg-gray-50")">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
                    Kanban
                </a>
                <a href="@ViewUrl("calendar")"
                   class="flex items-center gap-1.5 px-3 py-1.5 transition-colors @(Model.ViewMode=="calendar"?"bg-blue-600 text-white":"text-gray-600 hover:bg-gray-50")">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8h7M3 12h11M3 16h8M12 8h9M16 12h5M13 16h8"/></svg>
                    Timeline
                </a>
                <a href="@ViewUrl("team")"
                   class="flex items-center gap-1.5 px-3 py-1.5 border-l border-gray-200 transition-colors @(Model.ViewMode=="team"?"bg-blue-600 text-white":"text-gray-600 hover:bg-gray-50")">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Team
                </a>
            </div>
            <a href="@exportUrl"
               class="inline-flex items-center gap-1.5 border border-gray-200 bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium px-3 py-1.5 rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                CSV
            </a>
            <button onclick="openCanvas(null)"
                    class="inline-flex items-center gap-2 btn-accent text-sm px-4 py-1.5 rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                New Task
            </button>
        </div>
    </div>

    <!-- ── Status Chips ── -->
    <div class="flex flex-wrap gap-2">
        @foreach (var ws in Model.WorkStates)
        {
            var cnt = Model.StatusCounts.GetValueOrDefault(ws.Name, 0);
            var act = Model.Status == ws.Name;
            var cc  = act ? "bg-blue-600 text-white border-blue-600" : "bg-white text-gray-700 border-gray-200 hover:border-blue-300 hover:text-blue-600";
            <a href="@Url.Action("Index", new { search=Model.Search, project=Model.Project, property=Model.Property, owner=Model.Owner, status=act?"":ws.Name, priority=Model.Priority, dateFrom=Model.DateFrom, dateTo=Model.DateTo, page=1, pageSize=Model.PageSize, sort=Model.Sort, sortDir=Model.SortDir, view=Model.ViewMode, calYear=Model.CalYear, calMonth=Model.CalMonth })"
               class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium border transition-colors @cc">
                <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:@ws.Color"></span>
                @ws.Name
                <span class="@(act?"bg-white/20 text-white":"bg-gray-100 text-gray-600") rounded-full px-1.5 py-0.5 text-[10px] font-bold">@cnt</span>
            </a>
        }
        @if (!string.IsNullOrEmpty(Model.Status))
        {
            <a href="@Url.Action("Index", new { search=Model.Search, project=Model.Project, property=Model.Property, owner=Model.Owner, status="", priority=Model.Priority, dateFrom=Model.DateFrom, dateTo=Model.DateTo, page=1, pageSize=Model.PageSize, sort=Model.Sort, sortDir=Model.SortDir, view=Model.ViewMode, calYear=Model.CalYear, calMonth=Model.CalMonth })"
               class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium border border-gray-200 bg-white text-gray-500 hover:text-red-600">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg> Clear
            </a>
        }
    </div>

    <!-- ── Filter Bar ── -->
    <form method="get" action="/Tasks" class="bg-white border border-gray-200 rounded-xl p-3 flex flex-wrap gap-2 items-end">
        <input type="hidden" name="view"     value="@Model.ViewMode" />
        <input type="hidden" name="sort"     value="@Model.Sort" />
        <input type="hidden" name="sortDir"  value="@Model.SortDir" />
        <input type="hidden" name="calYear"  value="@Model.CalYear" />
        <input type="hidden" name="calMonth" value="@Model.CalMonth" />
        <div class="flex-1 min-w-48">
            <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
            <input type="text" name="search" value="@Model.Search" placeholder="Search goals, projects…"
                   class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="min-w-36">
            <label class="block text-xs font-medium text-gray-500 mb-1">Project</label>
            <select name="project" asp-items="@(new SelectList(Model.Projects,"Name","Name",Model.Project))"
                    class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">All Projects</option>
            </select>
        </div>
        <div class="min-w-36">
            <label class="block text-xs font-medium text-gray-500 mb-1">Property</label>
            <select name="property" asp-items="@(new SelectList(Model.Properties,"Name","Name",Model.Property))"
                    class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">All Properties</option>
            </select>
        </div>
        <div class="min-w-36">
            <label class="block text-xs font-medium text-gray-500 mb-1">Owner</label>
            <select name="owner" class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">All owners</option>
                @foreach (var o in Model.Owners)
                {
                    var sel = o.Name == Model.Owner ? "selected" : null;
                    <option value="@o.Name" selected="@sel">@o.Name</option>
                }
            </select>
        </div>
        <div class="min-w-32">
            <label class="block text-xs font-medium text-gray-500 mb-1">Status</label>
            <select name="status" class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">All Status</option>
                @foreach (var ws in Model.WorkStates)
                {
                    <option value="@ws.Name" selected="@(Model.Status == ws.Name ? "selected" : null)">@ws.Name</option>
                }
            </select>
        </div>
        <div class="min-w-28">
            <label class="block text-xs font-medium text-gray-500 mb-1">Priority</label>
            <select name="priority" asp-items="@(new SelectList(TaskTracker.Models.ViewModels.TaskListViewModel.AllPriorities.Select(p=>new SelectListItem(p,p)),"Value","Text",Model.Priority))"
                    class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">All Priority</option>
            </select>
        </div>
        <div class="min-w-36">
            <label class="block text-xs font-medium text-gray-500 mb-1">Target Date From</label>
            <input type="date" name="dateFrom" value="@Model.DateFrom"
                   class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="min-w-36">
            <label class="block text-xs font-medium text-gray-500 mb-1">Target Date To</label>
            <input type="date" name="dateTo" value="@Model.DateTo"
                   class="w-full border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <div class="flex gap-2">
            <button type="submit" class="btn-primary text-sm font-medium px-4 py-1.5 rounded-lg">Filter</button>
            <a href="@Url.Action("Index", new { owner=myDisplayName, search=Model.Search, project=Model.Project, property=Model.Property, status=Model.Status, priority=Model.Priority, dateFrom=Model.DateFrom, dateTo=Model.DateTo, pageSize=Model.PageSize, view=Model.ViewMode, calYear=Model.CalYear, calMonth=Model.CalMonth })"
               class="@(Model.Owner == myDisplayName ? "bg-blue-50 text-blue-700 border border-blue-200" : "bg-gray-100 hover:bg-gray-200 text-gray-700") text-sm font-medium px-4 py-1.5 rounded-lg transition-colors">My Tasks</a>
            <a href="@Url.Action("Index", new { owner="", search=Model.Search, project=Model.Project, property=Model.Property, status=Model.Status, priority=Model.Priority, dateFrom=Model.DateFrom, dateTo=Model.DateTo, pageSize=Model.PageSize, view=Model.ViewMode, calYear=Model.CalYear, calMonth=Model.CalMonth })"
               class="@(string.IsNullOrEmpty(Model.Owner) ? "bg-blue-50 text-blue-700 border border-blue-200" : "bg-gray-100 hover:bg-gray-200 text-gray-700") text-sm font-medium px-4 py-1.5 rounded-lg transition-colors">All Tasks</a>
        </div>
    </form>

    @* ════════════════════ TABLE VIEW ════════════════════ *@
    @if (Model.ViewMode == "table")
    {
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50">
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide w-10">#</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                            <a href="@SortUrl("goal")" class="flex items-center gap-1 hover:text-blue-600 group whitespace-nowrap">Goal <span class="@SortClass("goal") text-xs">@SortIcon("goal")</span></a>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                            <a href="@SortUrl("project")" class="flex items-center gap-1 hover:text-blue-600 group whitespace-nowrap">Project <span class="@SortClass("project") text-xs">@SortIcon("project")</span></a>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                            <a href="@SortUrl("property")" class="flex items-center gap-1 hover:text-blue-600 group whitespace-nowrap">Client <span class="@SortClass("property") text-xs">@SortIcon("property")</span></a>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide w-14">
                            <a href="@SortUrl("priority")" class="flex items-center gap-1 hover:text-blue-600 group whitespace-nowrap">Pri <span class="@SortClass("priority") text-xs">@SortIcon("priority")</span></a>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                            <a href="@SortUrl("owner")" class="flex items-center gap-1 hover:text-blue-600 group whitespace-nowrap">Owner <span class="@SortClass("owner") text-xs">@SortIcon("owner")</span></a>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">
                            <a href="@SortUrl("status")" class="flex items-center gap-1 hover:text-blue-600 group whitespace-nowrap">Status <span class="@SortClass("status") text-xs">@SortIcon("status")</span></a>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Created Date</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">
                            <span class="flex items-center gap-1" title="Estimated effort">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                Weight
                            </span>
                        </th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Exp. Start</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Exp. End</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Act. Start</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Act. End</th>
                        <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide w-20">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Tasks.Any())
                    {
                        <tr>
                            <td colspan="14" class="text-center py-16 text-gray-400">
                                <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                                <p class="font-medium">No tasks found</p>
                                <p class="text-xs mt-1">Try adjusting filters or <button onclick="openCanvas(null)" class="text-blue-600 hover:underline">create a new task</button></p>
                            </td>
                        </tr>
                    }
                    @{
                        int rowNum = (Model.Page - 1) * Model.PageSize + 1;
                        bool isAdmin = User.IsInRole("Admin");
                        string curDisplay = User.FindFirst("DisplayName")?.Value ?? "";
                        string curUser    = User.Identity?.Name ?? "";
                    }
                    @foreach (var task in Model.Tasks)
                    {
                        var detailId  = $"detail-{task.Id}";
                        var taskJson  = JsonSerializer.Serialize(task, jsonOpts);
                        var overdue   = IsOverdue(task.EndDate, task.Status);
                        var rowCls    = overdue ? "bg-red-50/40 hover:bg-red-50/60" : "hover:bg-gray-50";
                        var tCanEdit   = task.Status == "Not Started";
                        var tCanDelete = task.Status == "Not Started";
                        <tr class="border-b border-gray-50 cursor-pointer transition-colors @rowCls"
                            data-overdue="@overdue.ToString().ToLower()"
                            data-task="@taskJson"
                            onclick="openCanvas(JSON.parse(this.dataset.task))">
                            <td class="px-4 py-3 text-gray-400 text-xs">@rowNum</td>
                            <td class="px-4 py-3 max-w-xs">
                                <span class="font-medium text-gray-900 line-clamp-2">@task.Goal</span>
                            </td>
                            <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">@task.Project</td>
                            <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">@task.Property</td>
                            <td class="px-4 py-3">
                                @if (!string.IsNullOrEmpty(task.Priority))
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold @PriorityBadge(task.Priority)">@task.Priority</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (string.IsNullOrEmpty(task.Owner))
                                    {
                                        <span class="text-gray-300 text-xs">—</span>
                                    }
                                    else
                                    {
                                        @foreach (var ow in SplitOwners(task.Owner))
                                        {
                                            var owClr = ownerColorMap.GetValueOrDefault(ow, "#64748b");
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium text-white" style="background:@owClr">@ow</span>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3" onclick="event.stopPropagation()">
                                <button type="button"
                                        data-task-id="@task.Id"
                                        data-cur-status="@task.Status"
                                        onclick="toggleStatusMenu(this)"
                                        class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium border cursor-pointer hover:opacity-80 transition-opacity @StatusBadge(task.Status)">
                                    @task.Status
                                    <svg class="w-2.5 h-2.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>
                            </td>
                            <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap">
                                @task.CreatedAt.ToString("yyyy-MM-dd")
                            </td>
                            <td class="px-4 py-3 whitespace-nowrap">
                                @if (!string.IsNullOrEmpty(WeightLabel(task.Weight)))
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-cyan-50 text-cyan-700 border border-cyan-200">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        @WeightLabel(task.Weight)
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap">@task.StartDate</td>
                            <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap">@task.EndDate</td>
                            <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap">@task.ActualStartDate</td>
                            <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap">@task.ActualEndDate</td>
                            <td class="px-4 py-3 text-right" onclick="event.stopPropagation()">
                                <div class="flex items-center justify-end gap-1">
                                    <button data-task="@taskJson" onclick="openCanvas(JSON.parse(this.dataset.task))"
                                            class="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg"
                                            title="@(tCanEdit ? "Edit" : "View / Comment")">
                                        @if (tCanEdit)
                                        {
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                        }
                                        else
                                        {
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                        }
                                    </button>
                                    @if (tCanDelete)
                                    {
                                        <form method="post" action="/Tasks/Delete/@task.Id" id="del-task-@task.Id">
                                            @Html.AntiForgeryToken()
                                            <button type="button" onclick="swalDelete(document.getElementById('del-task-@task.Id'), null)" class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg" title="Delete">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                        <tr id="@detailId" class="hidden bg-blue-50/30">
                            <td colspan="14" class="px-6 py-4">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    @if (!string.IsNullOrEmpty(task.Notes))
                                    {
                                        <div><p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Notes</p><p class="text-sm text-gray-700 whitespace-pre-wrap">@task.Notes</p></div>
                                    }
                                    @if (!string.IsNullOrEmpty(task.RelatedFiles))
                                    {
                                        <div><p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Related Files</p><p class="text-sm text-gray-700 break-all">@task.RelatedFiles</p></div>
                                    }
                                    @if (string.IsNullOrEmpty(task.Notes) && string.IsNullOrEmpty(task.RelatedFiles))
                                    {
                                        <p class="text-sm text-gray-400 col-span-2">No notes or related files.</p>
                                    }
                                </div>
                            </td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1 || Model.Tasks.Any())
        {
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2 text-sm text-gray-500">
                    <span>Rows per page:</span>
                    <form method="get" action="/Tasks">
                        <input type="hidden" name="search"   value="@Model.Search" />
                        <input type="hidden" name="project"  value="@Model.Project" />
                        <input type="hidden" name="property" value="@Model.Property" />
                        <input type="hidden" name="owner"    value="@Model.Owner" />
                        <input type="hidden" name="status"   value="@Model.Status" />
                        <input type="hidden" name="priority" value="@Model.Priority" />
                        <input type="hidden" name="dateFrom" value="@Model.DateFrom" />
                        <input type="hidden" name="dateTo"   value="@Model.DateTo" />
                        <input type="hidden" name="sort"     value="@Model.Sort" />
                        <input type="hidden" name="sortDir"  value="@Model.SortDir" />
                        <input type="hidden" name="page"     value="1" />
                        <select name="pageSize" onchange="this.form.submit()"
                                asp-items="@(new SelectList(new[]{10,20,50,100}.Select(n=>new SelectListItem(n.ToString(),n.ToString())),"Value","Text",Model.PageSize.ToString()))"
                                class="border border-gray-200 rounded-lg px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </select>
                    </form>
                    <span>Showing @((Model.Page-1)*Model.PageSize+1)–@(Math.Min(Model.Page*Model.PageSize,Model.TotalCount)) of @Model.TotalCount</span>
                </div>
                <div class="flex items-center gap-1">
                    @{
                        string PageUrl(int p) => Url.Action("Index", new {
                            search=Model.Search, project=Model.Project, property=Model.Property,
                            owner=Model.Owner, status=Model.Status, priority=Model.Priority,
                            dateFrom=Model.DateFrom, dateTo=Model.DateTo,
                            page=p, pageSize=Model.PageSize, sort=Model.Sort, sortDir=Model.SortDir
                        }) ?? "#";
                        int sp2 = Math.Max(1, Model.Page-2);
                        int ep2 = Math.Min(Model.TotalPages, Model.Page+2);
                    }
                    <a href="@PageUrl(1)"              class="px-2 py-1.5 rounded-lg text-sm @(Model.Page<=1?"text-gray-300 pointer-events-none":"text-gray-600 hover:bg-gray-100")">«</a>
                    <a href="@PageUrl(Model.Page-1)"   class="px-2 py-1.5 rounded-lg text-sm @(Model.Page<=1?"text-gray-300 pointer-events-none":"text-gray-600 hover:bg-gray-100")">‹</a>
                    @for (int pg = sp2; pg <= ep2; pg++)
                    {
                        <a href="@PageUrl(pg)" class="px-3 py-1.5 rounded-lg text-sm font-medium @(pg==Model.Page?"bg-blue-600 text-white":"text-gray-600 hover:bg-gray-100")">@pg</a>
                    }
                    <a href="@PageUrl(Model.Page+1)"    class="px-2 py-1.5 rounded-lg text-sm @(Model.Page>=Model.TotalPages?"text-gray-300 pointer-events-none":"text-gray-600 hover:bg-gray-100")">›</a>
                    <a href="@PageUrl(Model.TotalPages)" class="px-2 py-1.5 rounded-lg text-sm @(Model.Page>=Model.TotalPages?"text-gray-300 pointer-events-none":"text-gray-600 hover:bg-gray-100")">»</a>
                </div>
            </div>
        }
    }

    @* ════════════════════ KANBAN VIEW ════════════════════ *@
    @if (Model.ViewMode == "kanban")
    {
        <div class="flex gap-4 overflow-x-auto pb-2 -mx-1 px-1" style="height:calc(100vh - 260px);min-height:400px">
            @for (int ci = 0; ci < Model.WorkStates.Count; ci++)
            {
                var colWs   = Model.WorkStates[ci];
                var colSt   = colWs.Name;
                var colClr  = colWs.Color;
                var colTs   = Model.Tasks.Where(t => t.Status == colSt).ToList();
                var colStJs = colSt.Replace("'", "\\'");
                <div data-kanban-col class="flex-shrink-0 w-72 bg-gray-50 rounded-xl border border-gray-200 overflow-hidden flex flex-col h-full">
                    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-white">
                        <div class="flex items-center gap-2">
                            <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background:@colClr"></div>
                            <span class="text-sm font-semibold text-gray-800">@colSt</span>
                        </div>
                        <span class="kanban-count text-xs font-bold bg-gray-100 text-gray-500 rounded-full px-2 py-0.5">@colTs.Count</span>
                    </div>
                    <div class="kanban-col-body p-3 space-y-2 overflow-y-auto flex-1 min-h-20 rounded-b-xl transition-all duration-150"
                         data-col-status="@colSt"
                         ondragover="event.preventDefault();this.classList.add('ring-2','ring-inset','ring-blue-400','bg-blue-50/40')"
                         ondragleave="if(!this.contains(event.relatedTarget))this.classList.remove('ring-2','ring-inset','ring-blue-400','bg-blue-50/40')"
                         ondrop="handleKanbanDrop(event,this,'@Html.Raw(colStJs)')">
                        <div class="kanban-empty text-center py-8 text-gray-300 text-xs @(colTs.Any() ? "hidden" : "")">Drop tasks here</div>
                        @{
                            bool kIsAdmin = User.IsInRole("Admin");
                            string kCurDisplay = User.FindFirst("DisplayName")?.Value ?? "";
                        }
                        @foreach (var kt in colTs)
                        {
                            var kj  = JsonSerializer.Serialize(kt, jsonOpts);
                            var kov = IsOverdue(kt.TargetDate, kt.Status);
                            var kCanEdit = kIsAdmin || SplitOwners(kt.Owner).Any(o => string.Equals(o, kCurDisplay, StringComparison.OrdinalIgnoreCase));
                            <div draggable="true"
                                 data-task-id="@kt.Id"
                                 ondragstart="handleKanbanDragStart(event)"
                                 ondragend="handleKanbanDragEnd(event)"
                                 data-task="@kj" onclick="openCanvas(JSON.parse(this.dataset.task))"
                                 class="kanban-card bg-white rounded-lg border @(kov ? "border-red-200 bg-red-50/20" : "border-gray-200") p-3 hover:border-blue-300 hover:shadow-sm transition-all @(kCanEdit ? "cursor-grab" : "cursor-pointer") select-none">
                                <div class="flex items-start justify-between gap-1 mb-1.5">
                                    @if (!string.IsNullOrEmpty(kt.Priority))
                                    {
                                        <span class="text-xs font-bold px-1.5 py-0.5 rounded @PriorityBadge(kt.Priority)">@kt.Priority</span>
                                    }
                                    @if (kov) { <span class="text-xs text-red-500 ml-auto" title="Overdue">⚠</span> }
                                </div>
                                <p class="text-sm text-gray-900 font-medium line-clamp-2 mb-2 leading-snug pointer-events-none">@kt.Goal</p>
                                <div class="flex flex-wrap gap-1 mb-2 pointer-events-none">
                                    @if (!string.IsNullOrEmpty(kt.Project))  { <span class="text-xs bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">@kt.Project</span> }
                                    @if (!string.IsNullOrEmpty(kt.Property)) { <span class="text-xs bg-purple-50 text-purple-700 px-1.5 py-0.5 rounded">@kt.Property</span> }
                                </div>
                                <div class="flex items-center justify-between text-xs pointer-events-none">
                                    <div class="flex flex-wrap gap-1">
                                        @{
                                            var kOwners = SplitOwners(kt.Owner).ToList();
                                        }
                                        @if (!kOwners.Any())
                                        {
                                            <span class="text-gray-300">—</span>
                                        }
                                        else
                                        {
                                            @foreach (var ko in kOwners.Take(3))
                                            {
                                                var koClr = ownerColorMap.GetValueOrDefault(ko, "#64748b");
                                                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-[9px] font-bold border border-white text-white" style="background:@koClr" title="@ko">@ko[0]</span>
                                            }
                                            @if (kOwners.Count > 3)
                                            {
                                                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-[9px] font-bold bg-gray-100 text-gray-500 border border-white">+@(kOwners.Count-3)</span>
                                            }
                                        }
                                    </div>
                                    <div class="flex items-center gap-1.5">
                                        @if (!string.IsNullOrEmpty(WeightLabel(kt.Weight)))
                                        {
                                            <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded-full bg-cyan-50 text-cyan-600 border border-cyan-200 text-[10px] font-medium">
                                                <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                @WeightLabel(kt.Weight)
                                            </span>
                                        }
                                        <span class="@(kov ? "text-red-500 font-medium" : "text-gray-400")">@kt.TargetDate</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
        <p class="text-xs text-gray-400 text-center">Drag cards between columns to change status &nbsp;·&nbsp; Click to edit &nbsp;·&nbsp; @Model.TotalCount tasks</p>
    }

    @* ════════════════════ TIMELINE VIEW ════════════════════ *@
    @if (Model.ViewMode == "calendar")
    {
        var cy   = Model.CalYear;
        var cm   = Model.CalMonth;
        var fd   = new DateTime(cy, cm, 1);
        var dim  = DateTime.DaysInMonth(cy, cm);
        var sdow = (int)fd.DayOfWeek;
        var ld   = new DateTime(cy, cm, dim);

        var prevM = fd.AddMonths(-1);
        var nextM = fd.AddMonths(1);
        string TlNav(DateTime m) => Url.Action("Index", new {
            search=Model.Search, project=Model.Project, property=Model.Property,
            owner=Model.Owner, status=Model.Status, priority=Model.Priority,
            dateFrom=Model.DateFrom, dateTo=Model.DateTo,
            pageSize=Model.PageSize, view="calendar", calYear=m.Year, calMonth=m.Month
        }) ?? "#";

        const int colW = 36;
        var tlEntries   = new List<(TaskItem T, int S, int E)>();
        var noDateItems = new List<TaskItem>();

        static bool TryParseDate(string? s, out DateTime d) {
            d = default;
            if (string.IsNullOrWhiteSpace(s)) return false;
            return DateTime.TryParseExact(s,
                new[]{"yyyy-MM-dd","dd/MM/yyyy","d/M/yyyy","dd/M/yyyy","d/MM/yyyy","MM/dd/yyyy","dd-MM-yyyy","yyyy/MM/dd"},
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out d)
                || DateTime.TryParse(s, out d);
        }

        foreach (var t in Model.Tasks)
        {
            DateTime? ts = null, te = null;
            if (TryParseDate(t.StartDate,  out var _s))  ts = _s;
            if (TryParseDate(t.EndDate,    out var _e))  te = _e;
            if (te == null && TryParseDate(t.TargetDate, out var _td)) te = _td;
            if (ts == null) ts = te;
            if (te == null) te = ts;

            if (ts != null && te != null && ts.Value <= ld && te.Value >= fd)
            {
                int bs = ts.Value < fd ? 1 : ts.Value.Day;
                int be = te.Value > ld ? dim : te.Value.Day;
                if (be < bs) be = bs;
                tlEntries.Add((t, bs, be));
            }
            else
            {
                noDateItems.Add(t);
            }
        }

        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">

            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
                <a href="@TlNav(prevM)" class="p-2 hover:bg-gray-100 rounded-lg transition-colors">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <div class="text-center">
                    <h2 class="text-lg font-semibold text-gray-900">@fd.ToString("MMMM yyyy")</h2>
                    <p class="text-xs text-gray-400">@tlEntries.Count task@(tlEntries.Count != 1 ? "s" : "") in timeline · @noDateItems.Count without dates</p>
                </div>
                <a href="@TlNav(nextM)" class="p-2 hover:bg-gray-100 rounded-lg transition-colors">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>

            <div class="overflow-x-auto">
                <div style="min-width:@(260 + dim * colW)px">

                    <div class="flex border-b border-gray-200 bg-gray-50">
                        <div class="shrink-0 border-r border-gray-200 px-4 py-2.5" style="width:260px">
                            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Task</span>
                        </div>
                        @for (int d = 1; d <= dim; d++)
                        {
                            bool dWe  = ((sdow + d - 1) % 7) is 0 or 6;
                            bool dTod = cy == today.Year && cm == today.Month && d == today.Day;
                            <div class="shrink-0 flex items-center justify-center text-xs border-r border-gray-100 @(dWe ? "bg-gray-100 text-gray-400" : dTod ? "bg-blue-50 text-blue-600 font-bold" : "text-gray-400")"
                                 style="width:@(colW)px;height:36px">@d</div>
                        }
                    </div>

                    @{
                        bool tlIsAdmin    = User.IsInRole("Admin");
                        string tlCurDisp  = User.FindFirst("DisplayName")?.Value ?? "";
                    }
                    @if (!tlEntries.Any())
                    {
                        <div class="text-center py-16 text-gray-400 text-sm">
                            No tasks with dates in @fd.ToString("MMMM yyyy")<br>
                            <span class="text-xs text-gray-300">Tasks need both a Start Date and End Date to appear on the timeline.</span>
                        </div>
                    }
                    @foreach (var (tlT, tlS, tlE) in tlEntries)
                    {
                        var tlJ       = JsonSerializer.Serialize(tlT, jsonOpts);
                        var barPx     = (tlS - 1) * colW;
                        var barW      = Math.Max(1, tlE - tlS + 1) * colW;
                        var tlCanEdit = tlIsAdmin || SplitOwners(tlT.Owner).Any(o => string.Equals(o, tlCurDisp, StringComparison.OrdinalIgnoreCase));
                        var barClr    = tlT.Status switch {
                            "Done"        => "#16a34a",
                            "On track"    => "#2563eb",
                            "Delayed"     => "#dc2626",
                            "On hold"     => "#6b7280",
                            "Testing"     => "#d97706",
                            "Not Started" => "#7c3aed",
                            _             => "#094f70"
                        };
                        var tlOw  = SplitOwners(tlT.Owner).FirstOrDefault() ?? "";
                        var tlOwC = ownerColorMap.GetValueOrDefault(tlOw, "#64748b");

                        <div class="flex border-b border-gray-50 hover:bg-blue-50/20" style="height:40px">
                            <div class="shrink-0 border-r border-gray-100 flex items-center gap-2 px-3" style="width:260px">
                                @if (!string.IsNullOrEmpty(tlT.Priority))
                                {
                                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded shrink-0 @PriorityBadge(tlT.Priority)">@tlT.Priority</span>
                                }
                                <button type="button" data-task="@tlJ" onclick="openCanvas(JSON.parse(this.dataset.task))"
                                        class="text-xs font-medium text-gray-800 hover:text-blue-600 text-left truncate flex-1 leading-tight">
                                    @tlT.Goal
                                </button>
                                @if (!string.IsNullOrEmpty(tlOw))
                                {
                                    <span class="shrink-0 inline-flex items-center justify-center w-5 h-5 rounded-full text-[9px] font-bold text-white"
                                          style="background:@tlOwC" title="@tlT.Owner">@tlOw[0]</span>
                                }
                            </div>
                            <div class="relative flex items-center" style="width:@(dim * colW)px;background:repeating-linear-gradient(90deg,transparent,transparent @(colW-1)px,#f3f4f6 @(colW-1)px,#f3f4f6 @(colW)px)">
                                @if (cy == today.Year && cm == today.Month)
                                {
                                    var tdX = (today.Day - 1) * colW + colW / 2;
                                    <div class="absolute top-0 bottom-0 w-px bg-blue-400/50 pointer-events-none" style="left:@(tdX)px"></div>
                                }
                                <button type="button" data-task="@tlJ" onclick="openCanvas(JSON.parse(this.dataset.task))"
                                        class="absolute h-6 rounded text-white text-[10px] font-medium truncate px-1.5 flex items-center shadow-sm hover:opacity-80 transition-opacity"
                                        style="left:@(barPx)px;width:@(barW)px;background:@barClr"
                                        title="@($"{tlT.Goal} · {tlT.StartDate}–{tlT.EndDate}")">
                                    @if (barW >= colW * 2) { @tlT.Goal }
                                </button>
                            </div>
                        </div>
                    }

                </div>
            </div>

            <div class="px-4 py-3 border-t border-gray-100 bg-gray-50/50 flex flex-wrap items-center gap-3">
                @foreach (var ws2 in Model.WorkStates)
                {
                    <span class="inline-flex items-center gap-1.5 text-xs text-gray-500">
                        <span class="w-3 h-3 rounded-sm inline-block" style="background:@ws2.Color"></span>@ws2.Name
                    </span>
                }
                <span class="text-xs text-gray-400 ml-auto">Click bars or task names to edit</span>
            </div>

        </div>

        @if (noDateItems.Any())
        {
            <div class="bg-white border border-gray-200 rounded-xl p-4">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">@noDateItems.Count task@(noDateItems.Count != 1 ? "s" : "") without dates</p>
                <div class="flex flex-wrap gap-2">
                    @foreach (var nd in noDateItems)
                    {
                        var ndJ      = JsonSerializer.Serialize(nd, jsonOpts);
                        <button type="button" data-task="@ndJ" onclick="openCanvas(JSON.parse(this.dataset.task))"
                                class="text-xs border border-gray-200 rounded-lg px-3 py-1.5 hover:bg-blue-50 hover:border-blue-200 text-gray-700 text-left max-w-xs truncate transition-colors">
                            @nd.Goal
                        </button>
                    }
                </div>
            </div>
        }
    }

    @* ── Team Timeline view ───────────────────────────────────────────── *@
    @if (Model.ViewMode == "team")
    {
        string tlFromStr = ViewBag.TlFrom as string ?? "";
        string tlToStr   = ViewBag.TlTo   as string ?? "";
        string tlModeStr = ViewBag.TlMode as string ?? "week";
        <style>
        .tl2-wrap{min-width:600px;font-family:inherit}

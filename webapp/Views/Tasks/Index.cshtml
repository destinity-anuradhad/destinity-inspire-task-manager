        .tl2-bar{position:absolute;border-radius:7px;background:#fff;box-shadow:0 1px 5px rgba(0,0,0,.1);display:flex;flex-direction:column;justify-content:center;padding:0 9px;cursor:pointer;overflow:hidden;transition:box-shadow .12s,transform .12s;border:1px solid rgba(0,0,0,.07)}
        .tl2-bar:hover{box-shadow:0 4px 12px rgba(0,0,0,.18);transform:translateY(-1px);z-index:5}
        .tl2-bar-strip{position:absolute;top:0;left:0;right:0;height:4px;border-radius:7px 7px 0 0}
        .tl2-bar-txt{color:#1e293b;font-size:11.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;margin-top:4px}
        .tl2-bar-pills{display:flex;gap:4px;margin-top:4px;overflow:hidden}
        .tl2-pill{display:inline-flex;align-items:center;padding:0 7px;height:16px;border-radius:99px;font-size:9.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100px;flex-shrink:0}

        .tl2-av{width:28px;height:28px;border-radius:8px;background:#094f70;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .tl2-nm{font-size:12px;font-weight:600;color:#374151;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .tl2-empty{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;color:#d1d5db;font-style:italic}
        .tl2-now-line{position:absolute;top:0;bottom:0;width:2px;background:#ef4444;z-index:6;pointer-events:none}
        .tl2-filter input[type=date]{border:1px solid #d1d5db;border-radius:8px;padding:4px 10px;font-size:12px;height:32px;color:#374151}
        .tl2-filter input[type=date]:focus{outline:none;border-color:#094f70}
        .tl2-btn{display:inline-flex;align-items:center;gap:4px;padding:4px 12px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;height:32px;border:1px solid transparent;text-decoration:none;transition:all .15s}
        .tl2-btn-apply{background:#094f70;color:#fff}.tl2-btn-apply:hover{background:#063a54}
        .tl2-btn-week{background:#fff;border-color:#094f70;color:#094f70}.tl2-btn-week:hover{background:#eff8ff}
        .tl2-btn-active{background:#eff6ff;border-color:#1d4ed8;color:#1d4ed8}
        .tl2-btn-today{background:#f1f5f9;border-color:#e2e8f0;color:#374151}.tl2-btn-today:hover{background:#e2e8f0}
        </style>

        <div class="bg-white border border-gray-200 rounded-xl px-4 py-3">
            <div class="tl2-filter flex items-center gap-2 flex-wrap">
                <span class="text-sm font-semibold text-gray-700 flex items-center gap-2 mr-1">
                    <svg class="w-4 h-4 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Team Timeline
                </span>
                <input type="date" id="tl2-from" value="@(tlModeStr != "today" ? tlFromStr : "")" />
                <span class="text-gray-400 text-sm">to</span>
                <input type="date" id="tl2-to" value="@(tlModeStr != "today" ? tlToStr : "")" />
                <button class="tl2-btn tl2-btn-apply" onclick="tl2Apply()">Apply</button>
                @{
                    var weekUrl = Url.Action("Index", new { view="team", search=Model.Search, project=Model.Project, property=Model.Property, owner=Model.Owner, status=Model.Status, priority=Model.Priority, pageSize=Model.PageSize }) ?? "/Tasks?view=team";
                    string dateBadge;
                    if (tlModeStr == "today") { dateBadge = DateTime.Today.ToString("dddd, d MMMM yyyy"); }
                    else if (DateTime.TryParse(tlFromStr, out var tfd2) && DateTime.TryParse(tlToStr, out var ttd2)) {
                        bool isFullMonth = tfd2.Day == 1 && ttd2 == tfd2.AddMonths(1).AddDays(-1);
                        dateBadge = isFullMonth ? tfd2.ToString("MMMM yyyy") : tfd2.ToString("d MMM") + " – " + ttd2.ToString("d MMM yyyy");
                    } else { dateBadge = tlFromStr + " – " + tlToStr; }
                }
                <a href="@weekUrl" class="tl2-btn @(tlModeStr=="week"?"tl2-btn-active":"tl2-btn-week")">This Week</a>
                <a href="/Tasks?view=team&tlmode=today" class="tl2-btn @(tlModeStr=="today"?"tl2-btn-active":"tl2-btn-today")">
                    <svg style="width:13px;height:13px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Today
                </a>
                <span class="ml-2 text-xs font-medium px-2 py-0.5 rounded-full @(tlModeStr=="today"?"bg-amber-100 text-amber-700":"bg-blue-50 text-blue-700")">
                    @dateBadge
                </span>
            </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <div class="flex items-center gap-4 flex-wrap px-4 py-2 border-b border-gray-100">
                @foreach (var (lbl2, clr2) in new[]{("On track","#094f70"),("Not Started","#8b5cf6"),("Testing","#f59e0b"),("Delayed","#ef4444"),("Done","#22c55e"),("On hold","#9ca3af")})
                {
                    <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#6b7280">
                        <span style="width:10px;height:10px;border-radius:3px;background:@clr2;flex-shrink:0"></span>@lbl2
                    </span>
                }
                @if (tlModeStr == "today")
                {
                    <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#6b7280;margin-left:auto">
                        <span style="width:2px;height:12px;background:#ef4444;border-radius:1px;flex-shrink:0"></span>Now
                    </span>
                }
            </div>
            <div style="overflow-x:auto;padding-bottom:8px">
                <div id="tl2-scroll" style="min-height:160px"></div>
            </div>
        </div>

        <script>
        (function () {
            var TL2_TASKS         = @Html.Raw(ViewBag.TlTasks          as string ?? "[]");
            var TL2_OWNERS        = @Html.Raw(ViewBag.TlOwners         as string ?? "[]");
            var TL2_PROJ_COLORS   = @Html.Raw(ViewBag.TlProjectColors  as string ?? "{}");
            var TL2_PROP_COLORS   = @Html.Raw(ViewBag.TlPropertyColors as string ?? "{}");
            var TL2_FROM = '@(tlFromStr)';
            var TL2_TO   = '@(tlToStr)';
            var TL2_MODE = '@(tlModeStr)';
            var SC = {'On track':'#094f70','Not Started':'#8b5cf6','Testing':'#f59e0b','Delayed':'#ef4444','Done':'#22c55e','On hold':'#9ca3af'};
            function hex2rgba(hex,a){var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return 'rgba('+r+','+g+','+b+','+a+')';}
            function pd(s){if(!s)return null;var m=s.match(/^(\d{4})-(\d{2})-(\d{2})/);if(!m)return null;return new Date(parseInt(m[1],10),parseInt(m[2],10)-1,parseInt(m[3],10));}
            function pdt(s){if(!s)return null;var m=s.match(/^(\d{4})-(\d{2})-(\d{2})[\sT](\d{2}):(\d{2})/);if(!m)return null;var h=parseInt(m[4],10),mn=parseInt(m[5],10);return{date:new Date(parseInt(m[1],10),parseInt(m[2],10)-1,parseInt(m[3],10)),h:h,mn:mn,tot:h*60+mn};}
            function sameDay(a,b){return a&&b&&a.getFullYear()===b.getFullYear()&&a.getMonth()===b.getMonth()&&a.getDate()===b.getDate();}
            function fmtDay(d){var dn=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],mo=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];return '<strong>'+dn[d.getDay()]+'<\/strong><br>'+d.getDate()+' '+mo[d.getMonth()];}
            function fmtTime(tot){var h=Math.floor(tot/60),mn=tot%60,ap=h<12?'AM':'PM',hh=h%12||12;return hh+':'+(mn<10?'0':'')+mn+' '+ap;}
            function ownerMatch(to,o){var p=(to||'').split(',');for(var i=0;i<p.length;i++){if(p[i].trim().toLowerCase()===o.toLowerCase())return true;}return false;}
            function assignLanes(bars){var ends=[];for(var i=0;i<bars.length;i++){var b=bars[i],pl=false;for(var j=0;j<ends.length;j++){if(b.lf>=ends[j]+0.004){b._lane=j;ends[j]=b.rt;pl=true;break;}}if(!pl){b._lane=ends.length;ends.push(b.rt);}}return ends.length||0;}
            function buildRows(fn){return TL2_OWNERS.map(function(owner){var bars=fn(owner).filter(function(x){return x!=null;});bars.sort(function(a,b){return a.lf-b.lf;});var nl=bars.length?assignLanes(bars):0;return{owner:owner,bars:bars,rowH:Math.max(64,nl*62+8)};});}
            function renderGrid(cols,getCI,rows){
                var n=cols.length,today=new Date();today.setHours(0,0,0,0);
                var html='<div class="tl2-wrap"><div class="tl2-hd"><div class="tl2-name-hd">DEVELOPER<\/div><div class="tl2-days-hd">';
                for(var i=0;i<n;i++){var ci=getCI(cols[i],today);html+='<div class="tl2-col-hd'+(ci.isNow?' tl2-col-now-hd':'')+'">'+ ci.label+'<\/div>';}
                html+='<\/div><\/div>';
                for(var r=0;r<rows.length;r++){
                    var row=rows[r];
                    var ini=(row.owner.split(/\s+/).map(function(w){return w.charAt(0)||'';}).join('').substring(0,2).toUpperCase())||'?';
                    html+='<div class="tl2-row" style="height:'+row.rowH+'px">';
                    html+='<div class="tl2-name-cell"><div class="tl2-av">'+ini+'<\/div><span class="tl2-nm">'+row.owner+'<\/span><\/div>';
                    html+='<div class="tl2-days-cell">';
                    for(var c=0;c<n;c++){var ci2=getCI(cols[c],today);html+='<div class="tl2-col-div'+(ci2.isNow?' tl2-col-div-today':'')+(ci2.isHour?' tl2-col-div-hr':'')+'" style="left:'+(c/n*100)+'%;width:'+(1/n*100)+'%"><\/div>';}
                    if(row.bars.length===0)html+='<div class="tl2-empty">no tasks<\/div>';
                    for(var bi=0;bi<row.bars.length;bi++){
                        var bar=row.bars[bi];
                        var sclr=SC[bar.task.status]||'#094f70';
                        var top=4+bar._lane*62;
                        var w=Math.max(bar.rt-bar.lf,0.012)*100;
                        var tip=bar.task.goal+(bar.task.property?' | '+bar.task.property:'')+(bar.task.project?' | '+bar.task.project:'');
                        var taskJson2=JSON.stringify(bar.task).replace(/"/g,'&quot;');
                        html+='<div class="tl2-bar" style="left:'+(bar.lf*100)+'%;width:'+w+'%;top:'+top+'px;height:56px;" title="'+tip.replace(/"/g,'&quot;')+'" data-task="'+taskJson2+'" onclick="openCanvas(JSON.parse(this.dataset.task))">';
                        html+='<div class="tl2-bar-strip" style="background:'+sclr+'"><\/div>';
                        html+='<span class="tl2-bar-txt">'+bar.task.goal+'<\/span>';
                        var ph='';
                        if(bar.task.property){var pc=TL2_PROP_COLORS[bar.task.property]||'#6b7280';ph+='<span class="tl2-pill" style="background:'+hex2rgba(pc,0.12)+';color:'+pc+'">'+bar.task.property+'<\/span>';}
                        if(bar.task.project){var jc=TL2_PROJ_COLORS[bar.task.project]||'#6b7280';ph+='<span class="tl2-pill" style="background:'+hex2rgba(jc,0.12)+';color:'+jc+'">'+bar.task.project+'<\/span>';}
                        if(ph)html+='<div class="tl2-bar-pills">'+ph+'<\/div>';
                        html+='<\/div>';
                    }
                    html+='<\/div><\/div>';
                }
                html+='<\/div>';
                document.getElementById('tl2-scroll').innerHTML=html;
            }
            function renderWeek(){
                var from=pd(TL2_FROM),to=pd(TL2_TO);if(!from||!to)return;
                var days=[],d=new Date(from.getTime());while(d<=to){days.push(new Date(d.getTime()));d.setDate(d.getDate()+1);}
                var totalMs=to.getTime()+86400000-from.getTime();
                var rows=buildRows(function(owner){return TL2_TASKS.filter(function(t){return ownerMatch(t.owner,owner)&&(t.startDate||t.endDate);}).map(function(t){var ts=pd(t.startDate)||pd(t.endDate),te=pd(t.endDate)||pd(t.startDate);if(!ts||!te)return null;var bs=Math.max(ts.getTime(),from.getTime()),be=Math.min(te.getTime()+86400000,to.getTime()+86400000);if(bs>=be)return null;return{lf:(bs-from.getTime())/totalMs,rt:(be-from.getTime())/totalMs,task:t};});});
                renderGrid(days,function(day,tod){return{label:fmtDay(day),isNow:sameDay(day,tod),isHour:false};},rows);
            }
            function renderDay(){
                var START=510,END=1050,SLOT=30,TOTAL=540;
                var slots=[],m=START;while(m<END){slots.push(m);m+=SLOT;}
                var today=new Date();today.setHours(0,0,0,0);
                var now=new Date(),nowMin=now.getHours()*60+now.getMinutes();
                var rows=buildRows(function(owner){return TL2_TASKS.filter(function(t){if(!t.startDate)return false;var ds=pd(t.startDate),de=t.endDate?pd(t.endDate):ds;if(!ds)return false;return ds<=today&&today<=(de||ds)&&ownerMatch(t.owner,owner);}).map(function(t){var ds=pd(t.startDate),de=t.endDate?pd(t.endDate):ds;var sdt=pdt(t.startDate),edt=t.endDate?pdt(t.endDate):null;var sm,em;var isMultiDay=de&&ds.getTime()!==de.getTime();if(isMultiDay){sm=START;em=END;}else if(sdt){sm=Math.max(sdt.tot,START);em=Math.min(edt?edt.tot:sdt.tot+60,END);}else{sm=START;em=END;}if(sm>=em)return null;return{lf:(sm-START)/TOTAL,rt:(em-START)/TOTAL,task:t};});});
                renderGrid(slots,function(slotMin){return{label:fmtTime(slotMin),isNow:(nowMin>=slotMin&&nowMin<slotMin+SLOT),isHour:(slotMin%60===0)};},rows);
                if(nowMin>=START&&nowMin<=END){var pct=(nowMin-START)/TOTAL*100;var cells=document.querySelectorAll('.tl2-days-cell');for(var ti=0;ti<cells.length;ti++){var ln=document.createElement('div');ln.className='tl2-now-line';ln.style.left=pct+'%';cells[ti].appendChild(ln);}}
            }
            window.tl2Apply=function(){var f=document.getElementById('tl2-from').value,t=document.getElementById('tl2-to').value;if(f&&t)window.location='/Tasks?view=team&tlfrom='+f+'&tlto='+t;};
            if(TL2_MODE==='today')renderDay();else renderWeek();
        })();
        </script>
    }

</div>

<script>
const CV_ME     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(myDisplayName));
const CV_COLORS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ownerColorMap));
const CV_ADMIN  = @Html.Raw(User.IsInRole("Admin") ? "true" : "false");

// Statuses available per item type
const ITEM_STATUSES = {
    'Epic':    ['New', 'Active', 'Closed'],
    'Feature': ['New', 'Active', 'Closed'],
    'Story':   ['New', 'Active', 'Resolved', 'Closed'],
    'Task':    ['To Do', 'In Progress', 'Done'],
    'Bug':     ['New', 'Active', 'Resolved', 'Closed'],
    '':        ['New', 'To Do', 'Active', 'In Progress', 'Resolved', 'Done', 'Closed'],
};
// Valid parent type for each item type
const PARENT_TYPE = { Feature: 'Epic', Story: 'Feature', Task: 'Story', Bug: 'Story' };
</script>

<!-- ═══ OFF-CANVAS BACKDROP ═══ -->
<div id="canvas-backdrop"
     class="fixed inset-0 bg-black/40 z-40 opacity-0 pointer-events-none transition-opacity duration-300"
     onclick="closeCanvas()"></div>

<style>@@keyframes slideInToast{from{transform:translateY(16px);opacity:0}to{transform:translateY(0);opacity:1}}</style>
<!-- ═══ OFF-CANVAS PANEL ═══ -->
<div id="task-canvas"
     class="fixed inset-y-0 right-0 w-full max-w-lg bg-white shadow-2xl z-50 translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 shrink-0">
        <div>
            <h2 id="canvas-title" class="text-lg font-semibold text-gray-900">New Task</h2>
            <div class="flex items-center gap-2 mt-0.5">
                <p id="canvas-subtitle" class="text-xs text-gray-400 hidden"></p>
                <span id="canvas-view-badge" class="hidden text-[10px] font-semibold uppercase tracking-wide text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full">View Only</span>
            </div>
        </div>
        <button onclick="closeCanvas()" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
    <!-- View-only placeholder: shown instead of form until user picks an action -->
    <div id="canvas-view-card" class="hidden flex-1 flex flex-col items-center justify-center gap-8 p-8">
        <p id="canvas-view-goal" class="text-base font-semibold text-gray-800 text-center leading-snug max-w-xs"></p>
        <div class="flex flex-col gap-3 w-full max-w-[240px]">
            <button type="button" id="canvas-edit-btn" onclick="_switchToEditMode()"
                    class="hidden w-full px-5 py-2.5 text-sm btn-primary rounded-lg flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit Task
            </button>
            <button type="button" onclick="_switchToCommentMode()"
                    class="w-full px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
                </svg>
                Add Comment
            </button>
        </div>
    </div>
    <form id="canvas-form" class="flex-1 overflow-y-auto px-6 py-5 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" id="cf-id" name="Id" value="0" />
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Goal <span class="text-red-500">*</span></label>
            <textarea id="cf-goal" name="Goal" rows="3" required placeholder="Describe the task goal…"
                      class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
        </div>
        <input type="hidden" id="cf-module-id"  name="ModuleId"  value="" />
        <input type="hidden" id="cf-client-id"  name="ClientId"  value="" />
        <input type="hidden" id="cf-item-type"  name="ItemType"  value="" />
        <input type="hidden" id="cf-parent-id"  name="ParentId"  value="" />
        <input type="hidden" id="cf-sprint-id"  name="SprintId"  value="" />
        <!-- Item Type + Parent -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Item Type</label>
                <select id="cf-item-type-sel" onchange="onItemTypeChange(this.value)"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                    <option value="">— None —</option>
                    <option value="Epic">🟦 Epic</option>
                    <option value="Feature">🟩 Feature</option>
                    <option value="Story">📋 Story</option>
                    <option value="Task">✅ Task</option>
                    <option value="Bug">🐛 Bug</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Parent</label>
                <select id="cf-parent-sel" onchange="document.getElementById('cf-parent-id').value = this.value"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                    <option value="">— None —</option>
                </select>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Module</label>
                <select id="cf-project" name="Project"
                        onchange="onModuleChange(this)"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                    <option value="">— Loading… —</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Client</label>
                <select id="cf-property" name="Property"
                        onchange="document.getElementById('cf-client-id').value = this.options[this.selectedIndex]?.dataset.cid ?? ''"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                    <option value="">— Loading… —</option>
                </select>
            </div>
        </div>
        <!-- Sprint -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Sprint</label>
            <select id="cf-sprint-sel" onchange="document.getElementById('cf-sprint-id').value = this.value"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">— Backlog —</option>
            </select>
        </div>
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Owner</label>
                <input type="hidden" id="cf-owner" name="Owner" />
                @if (User.IsInRole("Admin"))
                {
                    @* Admin: custom searchable multi-select picker *@
                    <div id="cf-owner-picker" class="relative">

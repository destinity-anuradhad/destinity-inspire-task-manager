        .tl2-name-cell{width:170px;min-width:170px;padding:8px 10px;display:flex;align-items:center;gap:8px;border-right:1px solid #e5e7eb;flex-shrink:0}
        .tl2-days-cell{flex:1;position:relative;overflow:hidden}
        .tl2-col-div{position:absolute;top:0;bottom:0;border-right:1px solid #f0f0f0}
